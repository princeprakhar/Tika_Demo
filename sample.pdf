3. PL/SQL Query Example
DECLARE
   v_total_salary NUMBER;
BEGIN
   SELECT SUM(salary)
   INTO v_total_salary
   FROM employees
   WHERE department = 'IT';

   DBMS_OUTPUT.PUT_LINE('Total IT Salary: ' || v_total_salary);


, unless OCR is enabled.
